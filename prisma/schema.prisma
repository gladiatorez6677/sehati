// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Base User model
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  nama          String
  tanggalLahir  DateTime
  jenisKelamin  String
  nomorTelepon  String
  alamat        String?
  role          UserRole
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  masyarakat    Masyarakat?
  perawat       Perawat?
  pushSubscriptions PushSubscription[]
}

enum UserRole {
  MASYARAKAT
  PERAWAT
  SURVEILLANCE
}

// Masyarakat specific data
model Masyarakat {
  id                String              @id @default(cuid())
  userId            String              @unique
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relations
  tekananDarah      TekananDarah[]
  manajemenStress   ManajemenStress[]
  controlKolesterol ControlKolesterol[]
  sesiRelaksasi     SesiRelaksasi[]
  gameScore         GameScore[]
  konsultasiAI      KonsultasiAI[]
  notification      Notification[]
  pengingatObat     PengingatObat[]
  responKuisioner   ResponKuisioner[]
}

// Perawat specific data
model Perawat {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nomorSTR       String?   @unique   // opsional: role SURVEILLANCE tanpa STR
  spesialisasi   String

  // Relations
  artikelKesehatan ArtikelKesehatan[]
  kuisioner        Kuisioner[]
}

// Tekanan Darah
model TekananDarah {
  id              String     @id @default(cuid())
  masyarakatId    String
  masyarakat      Masyarakat @relation(fields: [masyarakatId], references: [id], onDelete: Cascade)
  sistolik        Int
  diastolik       Int
  denyutNadi      Int
  tanggalPengukuran DateTime @default(now())
  catatan         String?
  kategori        String     // Normal, Prehipertensi, Hipertensi Stage 1, etc
  createdAt       DateTime   @default(now())
}

// Artikel Kesehatan
model ArtikelKesehatan {
  id          String    @id @default(cuid())
  perawatId   String
  perawat     Perawat   @relation(fields: [perawatId], references: [id], onDelete: Cascade)
  judul       String
  konten      String    @db.Text
  kategori    String
  tipeArtikel TipeArtikel @default(UTAMA)   // kelompok: Utama / Pendukung / Lokal Berbahasa Daerah
  gambar      String?
  ebook       String?   @db.Text   // path PDF e-book (opsional), disajikan via /uploads
  tags        String?
  status      ArticleStatus @default(DRAFT)
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  games       GameEdukasi[]
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TipeArtikel {
  UTAMA       // Artikel Utama
  PENDUKUNG   // Artikel Pendukung
  LOKAL       // Artikel Lokal Berbahasa Daerah
}

// Manajemen Stress
model ManajemenStress {
  id              String     @id @default(cuid())
  masyarakatId    String
  masyarakat      Masyarakat @relation(fields: [masyarakatId], references: [id], onDelete: Cascade)
  levelStress     Int        // 1-10
  gejala          String?
  pemicu          String?
  copingStrategy  String?
  rekomendasi     String?
  tanggalPenilaian DateTime @default(now())
  createdAt       DateTime  @default(now())
}

// Control Kolesterol
model ControlKolesterol {
  id              String     @id @default(cuid())
  masyarakatId    String
  masyarakat      Masyarakat @relation(fields: [masyarakatId], references: [id], onDelete: Cascade)
  totalKolesterol Int
  ldl             Int
  hdl             Int
  trigliserida    Int
  tanggalPemeriksaan DateTime @default(now())
  rekomendasi     String?
  createdAt       DateTime  @default(now())
}

// Fasilitas Kesehatan
model FasilitasKesehatan {
  id            String   @id @default(cuid())
  nama          String
  jenis         String   // RS, Klinik, Puskesmas, Apotek
  alamat        String
  latitude      Float
  longitude     Float
  nomorTelepon  String?
  jamBuka       String?
  jamTutup      String?
  layanan       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Relaksasi
model Relaksasi {
  id          String   @id @default(cuid())
  judul       String
  deskripsi   String   @db.Text
  tipe        TipeRelaksasi
  durasi      Int      // dalam detik
  audioUrl    String?
  videoUrl    String?
  instruksi   String?  @db.Text
  createdAt   DateTime @default(now())
  
  sesiRelaksasi SesiRelaksasi[]
}

enum TipeRelaksasi {
  MEDITASI
  MUSIK_RELAKSASI
  GUIDED_BREATHING
  PROGRESSIVE_RELAXATION
}

model SesiRelaksasi {
  id            String     @id @default(cuid())
  masyarakatId  String
  masyarakat    Masyarakat @relation(fields: [masyarakatId], references: [id], onDelete: Cascade)
  relaksasiId   String
  relaksasi     Relaksasi  @relation(fields: [relaksasiId], references: [id])
  durasi        Int        // durasi aktual dalam detik
  selesai       Boolean    @default(false)
  feedback      String?
  createdAt     DateTime   @default(now())
}

// Games Edukasi
model GameEdukasi {
  id          String   @id @default(cuid())
  nama        String
  deskripsi   String   @db.Text
  kategori    String   // Nutrisi, Olahraga, Penyakit, etc
  difficulty  GameDifficulty
  pertanyaan  Json     // Array of questions
  artikelId   String?  // artikel yang wajib dibaca sebelum main
  artikel     ArtikelKesehatan? @relation(fields: [artikelId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  gameScores  GameScore[]
}

enum GameDifficulty {
  MUDAH
  SEDANG
  SULIT
}

model GameScore {
  id            String      @id @default(cuid())
  masyarakatId  String
  masyarakat    Masyarakat  @relation(fields: [masyarakatId], references: [id], onDelete: Cascade)
  gameId        String
  game          GameEdukasi @relation(fields: [gameId], references: [id])
  score         Int
  waktuSelesai  Int         // dalam detik
  achievement   String?
  createdAt     DateTime    @default(now())
}

// Konsultasi AI
model KonsultasiAI {
  id            String     @id @default(cuid())
  masyarakatId  String
  masyarakat    Masyarakat @relation(fields: [masyarakatId], references: [id], onDelete: Cascade)
  topik         String
  messages      Json       // Array of chat messages
  status        ConsultationStatus @default(ACTIVE)
  eskalasi      Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

enum ConsultationStatus {
  ACTIVE
  CLOSED
  ESCALATED
}

// Notification
model Notification {
  id            String     @id @default(cuid())
  masyarakatId  String
  masyarakat    Masyarakat @relation(fields: [masyarakatId], references: [id], onDelete: Cascade)
  judul         String
  pesan         String
  tipe          NotificationType
  dibaca        Boolean    @default(false)
  createdAt     DateTime   @default(now())
}

enum NotificationType {
  REMINDER
  ALERT
  INFO
  WARNING
}

// Pengingat Minum Obat (dikelola oleh Masyarakat)
model PengingatObat {
  id           String     @id @default(cuid())
  masyarakatId String
  masyarakat   Masyarakat @relation(fields: [masyarakatId], references: [id], onDelete: Cascade)
  namaObat     String
  dosis        String?
  catatan      String?    @db.Text
  jam          String     // daftar "HH:MM" dipisah koma, mis. "07:00,20:00"
  hari         String     @default("0,1,2,3,4,5,6") // 0=Minggu..6=Sabtu, dipisah koma
  aktif        Boolean    @default(true)
  lastFiredKey String?    // penanda "YYYY-MM-DD HH:MM" terakhir dikirim (anti-duplikat)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Langganan Web Push (per perangkat/browser)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique @db.VarChar(512)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)
  createdAt DateTime @default(now())
}

// ===== Kuisioner (dikelola Perawat, diisi Masyarakat) =====
model Kuisioner {
  id         String                @id @default(cuid())
  perawatId  String
  perawat    Perawat               @relation(fields: [perawatId], references: [id], onDelete: Cascade)
  judul      String
  deskripsi  String?               @db.Text
  aktif      Boolean               @default(true)
  pertanyaan PertanyaanKuisioner[]
  respon     ResponKuisioner[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}

model PertanyaanKuisioner {
  id          String             @id @default(cuid())
  kuisionerId String
  kuisioner   Kuisioner          @relation(fields: [kuisionerId], references: [id], onDelete: Cascade)
  teks        String             @db.Text
  tipe        TipePertanyaan     @default(PILIHAN)
  opsi        String?            @db.Text // JSON array opsi untuk tipe PILIHAN
  urutan      Int                @default(0)
  jawaban     JawabanKuisioner[]
}

enum TipePertanyaan {
  PILIHAN
  TEKS
}

model ResponKuisioner {
  id           String             @id @default(cuid())
  kuisionerId  String
  kuisioner    Kuisioner          @relation(fields: [kuisionerId], references: [id], onDelete: Cascade)
  masyarakatId String
  masyarakat   Masyarakat         @relation(fields: [masyarakatId], references: [id], onDelete: Cascade)
  jawaban      JawabanKuisioner[]
  createdAt    DateTime           @default(now())
}

model JawabanKuisioner {
  id           String              @id @default(cuid())
  responId     String
  respon       ResponKuisioner     @relation(fields: [responId], references: [id], onDelete: Cascade)
  pertanyaanId String
  pertanyaan   PertanyaanKuisioner @relation(fields: [pertanyaanId], references: [id], onDelete: Cascade)
  nilai        String              @db.Text
}

// Video Kesehatan (dikelola oleh Perawat, ditonton oleh Masyarakat)
model VideoKesehatan {
  id          String        @id @default(cuid())
  judul       String
  deskripsi   String        @db.Text
  kategori    String
  url         String        @db.Text   // path lokal (/video/xxx.mp4) atau URL eksternal (YouTube/mp4)
  thumbnail   String?       @db.Text
  status      ArticleStatus @default(PUBLISHED)
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}